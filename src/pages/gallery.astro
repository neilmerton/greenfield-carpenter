---
import Layout from "../layouts/Layout.astro";

const categories = [
  "All",
  "Furniture",
  "Kitchens",
  "Staircases",
  "Flooring",
  "Restoration",
];

const projects = [
  {
    title: "Handmade Oak Kitchen",
    category: "Kitchens",
    tone: "warm",
    size: "large",
    location: "Uppermill",
    year: "2024",
  },
  {
    title: "Walnut Dining Table & Chairs",
    category: "Furniture",
    tone: "dark",
    size: "normal",
    location: "Greenfield",
    year: "2024",
  },
  {
    title: "Victorian Staircase Restoration",
    category: "Staircases",
    tone: "mid",
    size: "tall",
    location: "Delph",
    year: "2023",
  },
  {
    title: "Fitted Library & Study",
    category: "Furniture",
    tone: "light",
    size: "normal",
    location: "Dobcross",
    year: "2023",
  },
  {
    title: "Herringbone Oak Flooring",
    category: "Flooring",
    tone: "grain",
    size: "normal",
    location: "Mossley",
    year: "2023",
  },
  {
    title: "Painted Shaker Kitchen",
    category: "Kitchens",
    tone: "soft",
    size: "large",
    location: "Saddleworth",
    year: "2023",
  },
  {
    title: "Open-Riser Oak Staircase",
    category: "Staircases",
    tone: "dark",
    size: "tall",
    location: "Greenfield",
    year: "2022",
  },
  {
    title: "Antique Dresser Restoration",
    category: "Restoration",
    tone: "warm",
    size: "normal",
    location: "Diggle",
    year: "2022",
  },
  {
    title: "Custom Wardrobe Suite",
    category: "Furniture",
    tone: "mid",
    size: "normal",
    location: "Grasscroft",
    year: "2022",
  },
  {
    title: "Reclaimed Board Flooring",
    category: "Flooring",
    tone: "rustic",
    size: "normal",
    location: "Lydgate",
    year: "2022",
  },
  {
    title: "Home Office Joinery",
    category: "Furniture",
    tone: "light",
    size: "normal",
    location: "Uppermill",
    year: "2021",
  },
  {
    title: "Period Sash Window Restoration",
    category: "Restoration",
    tone: "grain",
    size: "normal",
    location: "Springhead",
    year: "2021",
  },
];
---

<Layout
  title="Gallery"
  description="Browse Greenfield Carpentry's project gallery — kitchens, furniture, staircases, flooring and restoration work in Greater Manchester."
>
  <div class="page-header">
    <span class="page-header__label">Our Work</span>
    <h1 class="page-header__title">Project Gallery</h1>
    <p class="page-header__subtitle">
      A selection of projects completed across Greenfield, Saddleworth, and
      Greater Manchester.
    </p>
  </div>

  <!-- Filter tabs -->
  <div
    class="gallery-filters"
    role="navigation"
    aria-label="Filter gallery by category"
  >
    <div class="container gallery-filters__inner">
      {
        categories.map((cat, i) => (
          <button
            class={`filter-btn${i === 0 ? " filter-btn--active" : ""}`}
            data-filter={cat}
            aria-pressed={i === 0 ? "true" : "false"}
          >
            {cat}
          </button>
        ))
      }
    </div>
  </div>

  <!-- Grid -->
  <section class="section" aria-label="Gallery grid">
    <div class="container">
      <div class="gallery-grid" id="galleryGrid">
        {
          projects.map((p) => (
            <article
              class={`gallery-item gallery-item--${p.size}`}
              data-category={p.category}
              aria-label={p.title}
            >
              <div class={`gallery-item__img gallery-item__img--${p.tone}`} />
              <div class="gallery-item__overlay">
                <div class="gallery-item__info">
                  <span class="gallery-item__cat">{p.category}</span>
                  <h3 class="gallery-item__title">{p.title}</h3>
                  <span class="gallery-item__meta">
                    {p.location} · {p.year}
                  </span>
                </div>
              </div>
            </article>
          ))
        }
      </div>

      <div class="gallery-cta">
        <p class="gallery-cta__text">
          Like what you see? Every project is bespoke — yours will be too.
        </p>
        <a href="/contact" class="btn btn--primary">Discuss Your Project</a>
      </div>
    </div>
  </section>

  <!-- Clients strip -->
  <section class="section section--alt" aria-label="Areas we serve">
    <div class="container" style="text-align: center;">
      <span class="section-label">Where We Work</span>
      <h2 class="section-title">Serving Greater Manchester</h2>
      <p
        class="section-intro"
        style="margin-inline: auto; margin-bottom: var(--space-10);"
      >
        Based in Greenfield, we work across Saddleworth and the wider Manchester
        area.
      </p>
      <div class="locations-list">
        {
          [
            "Greenfield",
            "Uppermill",
            "Delph",
            "Dobcross",
            "Diggle",
            "Mossley",
            "Oldham",
            "Tameside",
            "Stockport",
            "Manchester",
          ].map((loc) => <span class="location-chip">{loc}</span>)
        }
      </div>
    </div>
  </section>
</Layout>

<script>
  const filterBtns =
    document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const items = document.querySelectorAll<HTMLElement>(".gallery-item");

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;

      filterBtns.forEach((b) => {
        b.classList.remove("filter-btn--active");
        b.setAttribute("aria-pressed", "false");
      });
      btn.classList.add("filter-btn--active");
      btn.setAttribute("aria-pressed", "true");

      items.forEach((item) => {
        const match = filter === "All" || item.dataset.category === filter;
        item.style.display = match ? "" : "none";
      });
    });
  });
</script>

<style>
  /* Filters */
  .gallery-filters {
    background: var(--color-surface);
    border-bottom: var(--border);
    padding-block: var(--space-2);
    position: sticky;
    top: 64px;
    z-index: 50;
  }

  .gallery-filters__inner {
    display: flex;
    gap: var(--space-2);
    overflow-x: auto;
    scrollbar-width: none;
    padding-block: var(--space-2);
  }

  .gallery-filters__inner::-webkit-scrollbar {
    display: none;
  }

  .filter-btn {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: var(--space-2) var(--space-5);
    border-radius: 100px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    white-space: nowrap;
    transition:
      background var(--transition),
      color var(--transition),
      border-color var(--transition);
  }

  .filter-btn:hover {
    background: var(--color-parchment);
    color: var(--color-accent);
    border-color: var(--color-wood-light);
  }

  .filter-btn--active {
    background: var(--color-wood-mid);
    color: var(--color-cream);
    border-color: var(--color-wood-mid);
  }

  /* Gallery grid */
  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    grid-auto-rows: 220px;
    gap: var(--space-4);
  }

  .gallery-item {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    cursor: pointer;
  }

  .gallery-item__img {
    width: 100%;
    height: 100%;
    transition: transform var(--transition-slow);
  }

  .gallery-item:hover .gallery-item__img {
    transform: scale(1.05);
  }

  /* Tone variants — wood-inspired colour ranges */
  .gallery-item__img--warm {
    background: linear-gradient(145deg, #c4855a 0%, #7a4a28 60%, #4a2c17 100%);
  }
  .gallery-item__img--dark {
    background: linear-gradient(145deg, #2a1a0e 0%, #4a2c17 55%, #3d2b1f 100%);
  }
  .gallery-item__img--mid {
    background: linear-gradient(145deg, #7a4a28 0%, #a0622e 50%, #4a2c17 100%);
  }
  .gallery-item__img--light {
    background: linear-gradient(145deg, #d4a574 0%, #c4855a 55%, #7a4a28 100%);
  }
  .gallery-item__img--grain {
    background: linear-gradient(145deg, #b8860b 0%, #9a7020 45%, #4a2c17 100%);
  }
  .gallery-item__img--soft {
    background: linear-gradient(145deg, #ede4cf 0%, #c4a878 55%, #7a4a28 100%);
  }
  .gallery-item__img--rustic {
    background: linear-gradient(145deg, #5c3d22 0%, #8c5a32 55%, #2a1a0e 100%);
  }

  /* Overlay — always visible on mobile, hover-only on larger screens */
  .gallery-item__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(transparent 40%, rgba(26, 14, 7, 0.88) 100%);
    display: flex;
    align-items: flex-end;
    padding: var(--space-5);
    opacity: 1;
    transition: opacity var(--transition);
  }

  .gallery-item__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .gallery-item__cat {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold-light);
  }

  .gallery-item__title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    color: var(--color-cream);
    font-weight: normal;
  }

  .gallery-item__meta {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    color: var(--color-wood-light);
    opacity: 0.8;
  }

  /* Gallery CTA */
  .gallery-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    text-align: center;
    gap: var(--space-8);
    margin-top: var(--space-12);
    padding: var(--space-8);
    background: var(--color-parchment);
    border-radius: var(--radius);
    border-left: 4px solid var(--color-gold);
  }

  .gallery-cta__text {
    font-family: var(--font-body);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Locations */
  .locations-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
  }

  .location-chip {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--color-wood-mid);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: var(--space-2) var(--space-5);
    border-radius: 100px;
  }

  @media (min-width: 561px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 260px;
    }
    .gallery-item--tall {
      grid-row: span 2;
    }
    .gallery-item__overlay {
      opacity: 0;
    }
    .gallery-item:hover .gallery-item__overlay {
      opacity: 1;
    }
    .gallery-cta {
      flex-direction: row;
      text-align: left;
    }
  }

  @media (min-width: 960px) {
    .gallery-filters {
      top: 72px;
    }
  }

  @media (min-width: 901px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .gallery-item--large {
      grid-column: span 2;
    }
  }
</style>
