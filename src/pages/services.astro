---
import Layout from "../layouts/Layout.astro";
import { services, processSteps } from "../data/index.ts";
---

<Layout
  title="Services"
  description="Bespoke joinery and carpentry services in Greenfield — furniture, kitchens, staircases, doors, flooring, and restoration."
>
  <div class="page-header">
    <span class="page-header__label">What We Offer</span>
    <h1 class="page-header__title">Our Services</h1>
    <p class="page-header__subtitle">
      Every project begins with a conversation. Here is what we build, fit, and
      restore.
    </p>
  </div>

  <!-- Service nav anchors -->
  <nav class="services-nav" aria-label="Jump to service">
    <div class="container services-nav__inner">
      {
        services.map((s) => (
          <a href={`#${s.id}`} class="services-nav__link">
            {s.title}
          </a>
        ))
      }
    </div>
  </nav>

  <!-- Service sections -->
  {
    services.map((s, i) => (
      <section
        id={s.id}
        class={`section service-section${i % 2 !== 0 ? " section--alt" : ""}`}
        aria-label={s.title}
      >
        <div class="container service-section__grid">
          <div class="service-section__content">
            <span class="section-label">
              {s.icon} {s.title}
            </span>
            <h2 class="service-section__title">{s.title}</h2>
            <p class="service-section__summary">{s.summary}</p>
            <p class="service-section__detail">{s.detail}</p>

            <div class="materials">
              <h3 class="materials__heading">Common Materials</h3>
              <ul class="materials__list">
                {s.materials.map((m) => (
                  <li class="materials__item">{m}</li>
                ))}
              </ul>
            </div>

            <a
              href="/contact"
              class="btn btn--primary"
              style="margin-top: var(--space-6);"
            >
              Enquire About This Service
            </a>
          </div>

          <aside class="service-section__visual" aria-hidden="true">
            <div class={`service-visual service-visual--${i}`} />
            <div class="service-visual__badge">
              <span class="service-visual__badge-icon">{s.icon}</span>
            </div>
          </aside>
        </div>
      </section>
    ))
  }

  <!-- Process strip -->
  <section class="section section--dark" aria-label="Our process">
    <div class="container">
      <span class="section-label" style="color: var(--color-gold-light);"
        >How It Works</span
      >
      <h2
        class="section-title"
        style="color: var(--color-cream); margin-bottom: var(--space-12);"
      >
        From Idea to Installation
      </h2>
      <div class="process-steps">
        {
          processSteps.map((step) => (
            <div class="process-step">
              <span class="process-step__num">{step.n}</span>
              <h3 class="process-step__title">{step.title}</h3>
              <p class="process-step__desc">{step.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="text-align:center;">
    <div class="container">
      <h2 class="section-title">Ready to Discuss Your Project?</h2>
      <p
        class="section-intro"
        style="margin-inline: auto; margin-bottom: var(--space-8);"
      >
        We offer a free, no-obligation home visit anywhere in Greater Manchester
        and Saddleworth.
      </p>
      <a href="/contact" class="btn btn--primary">Get in Touch</a>
    </div>
  </section>
</Layout>

<style>
  .services-nav {
    background: var(--color-surface);
    border-bottom: var(--border);
    position: sticky;
    top: 64px;
    z-index: 50;
  }

  .services-nav__inner {
    display: flex;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .services-nav__inner::-webkit-scrollbar {
    display: none;
  }

  .services-nav__link {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding: var(--space-4) var(--space-5);
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition:
      color var(--transition),
      border-color var(--transition);
  }

  .services-nav__link:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-gold);
  }

  /* Service sections */
  .service-section__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-items: center;
  }

  .service-section__title {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
  }

  .service-section__summary {
    font-size: var(--text-lg);
    font-style: italic;
    color: var(--color-text-muted);
    margin-bottom: var(--space-5);
    line-height: var(--leading-loose);
  }

  .service-section__detail {
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
    margin-bottom: var(--space-6);
  }

  /* Materials */
  .materials__heading {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-3);
  }

  .materials__list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .materials__item {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    background: var(--color-parchment);
    color: var(--color-wood-dark);
    padding: var(--space-1) var(--space-3);
    border-radius: 100px;
    border: 1px solid var(--color-parchment-mid);
    letter-spacing: 0.05em;
  }

  /* Visual panels */
  .service-section__visual {
    display: none;
    position: relative;
  }

  .service-visual {
    aspect-ratio: 4/3;
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
  }

  .service-visual--0 {
    background: linear-gradient(135deg, #c4855a 0%, #7a4a28 50%, #3d2410 100%);
  }
  .service-visual--1 {
    background: linear-gradient(135deg, #4a2c17 0%, #a0622e 55%, #6b3f2a 100%);
  }
  .service-visual--2 {
    background: linear-gradient(135deg, #3a5c3e 0%, #4a2c17 55%, #2a1a0e 100%);
  }
  .service-visual--3 {
    background: linear-gradient(135deg, #6b3f2a 0%, #9a7020 55%, #4a2c17 100%);
  }
  .service-visual--4 {
    background: linear-gradient(135deg, #d4a574 0%, #a0622e 55%, #4a2c17 100%);
  }
  .service-visual--5 {
    background: linear-gradient(135deg, #2a1a0e 0%, #6b3f2a 55%, #c4855a 100%);
  }

  .service-visual__badge {
    position: absolute;
    bottom: -16px;
    right: -16px;
    width: 64px;
    height: 64px;
    background: var(--color-wood-mid);
    border: 3px solid var(--color-gold);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    box-shadow: var(--shadow);
  }

  /* Process */
  .process-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  .process-step {
    border-left: 1px solid rgba(196, 149, 42, 0.3);
    padding-left: var(--space-6);
  }

  .process-step__num {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-gold);
    opacity: 0.4;
    line-height: 1;
    margin-bottom: var(--space-3);
  }

  .process-step__title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    color: var(--color-cream);
    margin-bottom: var(--space-3);
  }

  .process-step__desc {
    font-size: var(--text-sm);
    color: var(--color-wood-light);
    line-height: var(--leading-loose);
    margin: 0;
    opacity: 0.85;
  }

  @media (min-width: 561px) {
    .process-steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .services-nav {
      top: 72px;
    }
  }

  @media (min-width: 1025px) {
    .service-section__grid {
      grid-template-columns: 1fr 420px;
      gap: var(--space-16);
    }
    .service-section__visual {
      display: block;
    }
    .process-steps {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
