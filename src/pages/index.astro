---
import Layout from "../layouts/Layout.astro";
import {
  credentials,
  homeServices,
  galleryTeaser,
  testimonials,
} from "../data/index.ts";
---

<Layout
  title="Home"
  description="Greenfield Carpentry — bespoke joinery, furniture and woodworking in Greenfield, near Manchester since 1987."
>
  <section class="hero" aria-label="Introduction">
    <div class="hero__bg" aria-hidden="true"></div>
    <div class="container hero__content">
      <span class="hero__label">Est. 1987 · Greenfield, Manchester</span>
      <h1 class="hero__title">The Art of<br />Fine Carpentry</h1>
      <p class="hero__lead">
        Bespoke joinery and hand-crafted woodwork, made to last a lifetime.
        Serving homes across Greenfield, Saddleworth, and Greater Manchester.
      </p>
      <div class="hero__actions">
        <a href="/services" class="btn btn--primary">Our Services</a>
        <a href="/contact" class="btn btn--ghost">Get a Quote</a>
      </div>
    </div>
  </section>

  <section class="credentials" aria-label="Credentials">
    <div class="container credentials__grid">
      {
        credentials.map((c, i) => (
          <Fragment>
            <div class="credential">
              <span class="credential__number">{c.number}</span>
              <span class="credential__label">{c.label}</span>
            </div>
            {i < credentials.length - 1 && (
              <div class="credential__divider" aria-hidden="true" />
            )}
          </Fragment>
        ))
      }
    </div>
  </section>

  <section class="section" aria-label="About us">
    <div class="container about-home">
      <div class="about-home__image" aria-hidden="true">
        <div class="wood-image wood-image--workshop">
          <div class="wood-image__overlay">
            <span class="wood-image__caption">The Workshop, Greenfield</span>
          </div>
        </div>
      </div>
      <div class="about-home__text">
        <span class="section-label">Our Story</span>
        <h2 class="section-title">Craftsmanship Over Flatpack</h2>
        <p>
          Founded by master craftsman Steve Dixon in 1987, Greenfield Carpentry
          has built a reputation for uncompromising quality across the
          Saddleworth valley and Greater Manchester areas.
        </p>
        <p>
          Every piece we make begins with a conversation. We take time to
          understand how you live, what you need, and what will endure. Then we
          set to work with seasoned hardwoods, traditional joinery techniques,
          and an eye for detail that never wavers.
        </p>
        <a
          href="/about"
          class="btn btn--outline"
          style="margin-top: var(--space-6);">Learn more</a
        >
      </div>
    </div>
  </section>

  <section class="section section--alt" aria-label="Services overview">
    <div class="container">
      <div class="section-header">
        <span class="section-label">What We Do</span>
        <div class="title-rule">
          <h2 class="section-title" style="margin:0;">Our Craft</h2>
        </div>
        <p class="section-intro">
          From bespoke fitted furniture to full kitchen installations, every job
          receives the same care and attention, no matter how large or small.
        </p>
      </div>

      <div class="services-grid">
        {
          homeServices.map((s) => (
            <article class="service-card">
              <h3 class="service-card__title">{s.title}</h3>
              <p class="service-card__desc">{s.desc}</p>
            </article>
          ))
        }
      </div>

      <div style="text-align:center; margin-top: var(--space-12);">
        <a href="/services" class="btn btn--primary">View All Services</a>
      </div>
    </div>
  </section>

  <section class="section" aria-label="Recent work">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Our Work</span>
        <div class="title-rule">
          <h2 class="section-title" style="margin:0;">Recent Projects</h2>
        </div>
      </div>

      <div class="gallery-teaser">
        {
          galleryTeaser.map((p) => (
            <a
              href="/gallery"
              class="gallery-thumb"
              aria-label={`View ${p.label} in gallery`}
            >
              <div class={`gallery-thumb__img gallery-thumb__img--${p.tone}`} />
              <span class="gallery-thumb__label">{p.label}</span>
            </a>
          ))
        }
      </div>

      <div style="text-align:center; margin-top: var(--space-10);">
        <a href="/gallery" class="btn btn--outline">Browse Gallery</a>
      </div>
    </div>
  </section>

  <section class="section section--dark" aria-label="Testimonials">
    <div class="container">
      <span class="section-label" style="color: var(--color-gold-light);"
        >What Clients Say</span
      >
      <div class="testimonials-grid">
        {
          testimonials.map((t) => (
            <blockquote class="testimonial">
              <p class="testimonial__quote">"{t.quote}"</p>
              <footer class="testimonial__footer">
                <span class="testimonial__author">{t.author}</span>
                <span class="testimonial__location">{t.location}</span>
              </footer>
            </blockquote>
          ))
        }
      </div>
    </div>
  </section>

  <section class="cta-banner" aria-label="Call to action">
    <div class="container cta-banner__inner">
      <div>
        <h2 class="cta-banner__title">Ready to Start Your Project?</h2>
        <p class="cta-banner__sub">
          Get in touch for a free consultation and no-obligation quote.
        </p>
      </div>
      <div class="cta-banner__actions">
        <a href="/contact" class="btn btn--primary">Request a Quote</a>
        <a href="tel:+441457860000" class="btn btn--ghost">01457 860 000</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    align-items: center;
    background: var(--color-wood-darkest);
    display: flex;
    min-height: 60vh;
    overflow: hidden;
    position: relative;
  }

  .hero__bg {
    background-image:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 4px,
        rgba(255, 255, 255, 0.012) 4px,
        rgba(255, 255, 255, 0.012) 8px
      ),
      repeating-linear-gradient(
        180deg,
        transparent,
        transparent 60px,
        rgba(164, 98, 46, 0.07) 60px,
        rgba(164, 98, 46, 0.07) 61px
      ),
      radial-gradient(
        ellipse at 70% 50%,
        rgba(122, 74, 40, 0.35) 0%,
        transparent 65%
      );
    inset: 0;
    position: absolute;
  }

  .hero__content {
    max-width: 660px;
    padding-block: var(--space-32);
    position: relative;
    z-index: 1;
  }

  .hero__label {
    border-radius: var(--radius-sm);
    border: 1px solid rgba(196, 149, 42, 0.4);
    color: var(--color-gold-light);
    display: inline-block;
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.22em;
    margin-bottom: var(--space-5);
    padding: var(--space-2) var(--space-4);
    text-transform: uppercase;
  }

  .hero__title {
    color: var(--color-cream);
    font-family: var(--font-heading);
    font-size: clamp(3rem, 7vw, 5rem);
    font-weight: normal;
    letter-spacing: 0.01em;
    line-height: 1.05;
    margin-bottom: var(--space-6);
  }

  .hero__lead {
    color: var(--color-wood-light);
    font-size: var(--text-md);
    line-height: var(--leading-loose);
    margin-bottom: var(--space-10);
    max-width: 48ch;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .credentials {
    background-color: var(--color-wood-mid);
    padding-block: var(--space-8);
  }

  .credentials__grid {
    align-items: center;
    display: flex;
    gap: var(--space-8);
    flex-wrap: wrap;
    justify-content: center;
  }

  .credential {
    align-items: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    text-align: center;
  }

  .credential__number {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--color-cream);
    line-height: 1;
  }

  .credential__label {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-wood-light);
  }

  .credential__divider {
    display: none;
    width: 1px;
    height: 48px;
    background: rgba(255, 255, 255, 0.2);
  }

  @media (min-width: 641px) {
    .credentials__grid {
      gap: var(--space-12);
    }
    .credential__divider {
      display: block;
    }
  }

  .about-home {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-items: center;
  }

  .wood-image {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 4/3;
    background: var(--color-wood-dark);
  }

  .wood-image--workshop {
    background-image:
      repeating-linear-gradient(
        85deg,
        rgba(164, 98, 46, 0.15),
        rgba(164, 98, 46, 0.15) 3px,
        transparent 3px,
        transparent 18px
      ),
      repeating-linear-gradient(
        175deg,
        rgba(122, 74, 40, 0.12),
        rgba(122, 74, 40, 0.12) 2px,
        transparent 2px,
        transparent 24px
      ),
      linear-gradient(135deg, #4a2c17 0%, #6b3f2a 40%, #3d2410 100%);
    box-shadow: var(--shadow-lg);
  }

  .wood-image::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 30% 60%,
      rgba(255, 200, 130, 0.1) 0%,
      transparent 60%
    );
  }

  .wood-image__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-4) var(--space-5);
    background: linear-gradient(transparent, rgba(26, 14, 7, 0.7));
  }

  .wood-image__caption {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-wood-light);
  }

  @media (min-width: 960px) {
    .about-home {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-16);
    }
  }

  /* ---- Services grid ---- */
  .section-header {
    margin-bottom: var(--space-12);
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  .service-card {
    background: var(--color-surface);
    border: var(--border);
    border-radius: var(--radius);
    padding: var(--space-8);
    transition:
      box-shadow var(--transition),
      transform var(--transition);
    border-top: 3px solid var(--color-gold);
  }

  .service-card:hover {
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }

  .service-card__icon {
    display: block;
    font-size: 1.8rem;
    margin-bottom: var(--space-4);
    line-height: 1;
  }

  .service-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    margin-bottom: var(--space-3);
    color: var(--color-ink);
  }

  .service-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
    margin: 0;
  }

  @media (min-width: 561px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 901px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ---- Gallery teaser ---- */
  .gallery-teaser {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .gallery-thumb {
    display: block;
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 3/4;
    text-decoration: none;
  }

  .gallery-thumb__img {
    width: 100%;
    height: 100%;
    transition: transform var(--transition-slow);
  }

  .gallery-thumb:hover .gallery-thumb__img {
    transform: scale(1.04);
  }

  .gallery-thumb__img--warm {
    background: linear-gradient(160deg, #c4855a 0%, #7a4a28 60%, #4a2c17 100%);
  }
  .gallery-thumb__img--dark {
    background: linear-gradient(160deg, #3d2b1f 0%, #5a3820 60%, #2a1a0e 100%);
  }
  .gallery-thumb__img--mid {
    background: linear-gradient(160deg, #a0622e 0%, #6b3f2a 55%, #3d2410 100%);
  }
  .gallery-thumb__img--light {
    background: linear-gradient(160deg, #d4a574 0%, #a0622e 55%, #6b3f2a 100%);
  }

  .gallery-thumb__label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-3) var(--space-4);
    background: linear-gradient(transparent, rgba(26, 14, 7, 0.85));
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    color: var(--color-cream);
    line-height: 1.3;
  }

  @media (min-width: 960px) {
    .gallery-teaser {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* ---- Testimonials ---- */
  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    margin-top: var(--space-8);
  }

  .testimonial {
    border-left: 3px solid var(--color-gold);
    padding-left: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .testimonial__quote {
    font-family: var(--font-body);
    font-style: italic;
    font-size: var(--text-md);
    color: var(--color-parchment);
    line-height: var(--leading-loose);
    margin: 0;
    opacity: 0.9;
  }

  .testimonial__footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .testimonial__author {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-wood-light);
  }

  .testimonial__location {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold-light);
    opacity: 0.7;
  }

  @media (min-width: 900px) {
    .testimonials-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-8);
    }
  }

  /* ---- CTA Banner ---- */
  .cta-banner {
    background: var(--color-wood-mid);
    padding-block: var(--space-16);
    background-image: repeating-linear-gradient(
      90deg,
      transparent,
      transparent 5px,
      rgba(255, 255, 255, 0.015) 5px,
      rgba(255, 255, 255, 0.015) 10px
    );
  }

  .cta-banner__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .cta-banner__title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--color-cream);
    margin-bottom: var(--space-2);
  }

  .cta-banner__sub {
    font-size: var(--text-md);
    color: var(--color-wood-light);
    margin: 0;
  }

  .cta-banner__actions {
    display: flex;
    gap: var(--space-4);
    flex-direction: column;
    flex-shrink: 0;
    flex-wrap: wrap;

    @media (min-width: 561px) {
      flex-direction: row;
    }

    .btn--primary {
      border-color: var(--color-wood-dark);
    }
  }
</style>
