---
import Layout from "../layouts/Layout.astro";
import { team, values, accreditations } from "../data/index.ts";
---

<Layout
  title="About"
  description="Meet the team behind Greenfield Carpentry — a family business built on traditional craftsmanship since 1987."
>
  <div class="page-header">
    <span class="page-header__label">Our Story</span>
    <h1 class="page-header__title">About Us</h1>
    <p class="page-header__subtitle">
      A family carpentry business rooted in Greenfield since 1987.
    </p>
  </div>

  <!-- History section -->
  <section class="section" aria-label="Our history">
    <div class="container history-grid">
      <div class="history-text">
        <span class="section-label">The Beginning</span>
        <h2 class="section-title">Born Out of a<br />Love for Wood</h2>
        <p>
          Robert Hartley started Greenfield Carpentry in 1987 from a workshop at
          the bottom of his garden in Chew Valley Road. He had just enough space
          for a bandsaw, a planer, and a bench, and enough talent to fill an
          order book within six months purely by word of mouth.
        </p>
        <p>
          The business grew slowly and deliberately, always centred on quality
          rather than volume. Robert took on his first apprentice in 1993, a
          tradition the business has maintained ever since. Today, the workshop
          occupies a purpose-built unit on a local trading estate, with a small
          showroom attached where clients can feel timber samples and examine
          joinery details at close range.
        </p>
        <p>
          The Hartley family still runs the business day to day. Robert's son
          Daniel joined in 2008, and designer Sarah Brennan completed the core
          team in 2015. Between the three of them they bring more than seventy
          years of combined experience to every project that comes through the
          door.
        </p>
      </div>

      <div class="history-visual" aria-hidden="true">
        <div class="history-img history-img--main"></div>
        <div class="history-img history-img--small"></div>
        <div class="history-badge">
          <span class="history-badge__year">1987</span>
          <span class="history-badge__label">Est.</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt" aria-label="Our values">
    <div class="container">
      <span class="section-label">What We Stand For</span>
      <h2 class="section-title">Our Values</h2>
      <div class="values-grid">
        {
          values.map((v) => (
            <div class="value-card">
              <div class="value-card__ornament" aria-hidden="true">
                ✦
              </div>
              <h3 class="value-card__title">{v.title}</h3>
              <p class="value-card__desc">{v.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--dark" aria-label="Accreditations">
    <div class="container">
      <span class="section-label" style="color: var(--color-gold-light);"
        >Credentials</span
      >
      <h2
        class="section-title"
        style="color: var(--color-cream); margin-bottom: var(--space-12);"
      >
        Accreditations & Memberships
      </h2>
      <div class="accreditations-grid">
        {
          accreditations.map((a) => (
            <div class="accreditations-card">
              <span class="accreditations-card__icon" aria-hidden="true">
                ✦
              </span>
              <h3 class="accreditations-card__title">{a.title}</h3>
              <p class="accreditations-card__detail">{a.detail}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section" style="text-align: center;">
    <div class="container">
      <h2 class="section-title">Come and Visit the Workshop</h2>
      <p
        class="section-intro"
        style="margin-inline: auto; margin-bottom: var(--space-8);"
      >
        We welcome visits to our Greenfield workshop and showroom. See the
        timber, feel the finishes, and meet the team in person.
      </p>
      <a href="/contact" class="btn btn--primary">Get in Touch</a>
    </div>
  </section>
</Layout>

<style>
  /* History */
  .history-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-items: center;
  }

  .history-text p {
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
  }

  .history-visual {
    position: relative;
    height: 340px;
  }

  .history-img {
    position: absolute;
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
  }

  .history-img--main {
    width: 78%;
    height: 85%;
    top: 0;
    right: 0;
    background: linear-gradient(145deg, #7a4a28 0%, #4a2c17 55%, #2a1a0e 100%);
    background-image:
      repeating-linear-gradient(
        88deg,
        rgba(255, 255, 255, 0.015),
        rgba(255, 255, 255, 0.015) 2px,
        transparent 2px,
        transparent 14px
      ),
      linear-gradient(145deg, #7a4a28 0%, #4a2c17 55%, #2a1a0e 100%);
  }

  .history-img--small {
    width: 48%;
    height: 48%;
    bottom: 0;
    left: 0;
    background: linear-gradient(145deg, #c4855a 0%, #a0622e 55%, #6b3f2a 100%);
    border: 4px solid var(--color-cream);
  }

  .history-badge {
    position: absolute;
    top: 50%;
    left: 38%;
    transform: translate(-50%, -50%);
    width: 80px;
    height: 80px;
    background: var(--color-wood-mid);
    border: 3px solid var(--color-gold);
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow);
    z-index: 1;
  }

  .history-badge__year {
    font-family: var(--font-heading);
    font-size: var(--text-md);
    color: var(--color-cream);
    line-height: 1;
  }

  .history-badge__label {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold-light);
  }

  @media (min-width: 1025px) {
    .history-grid {
      grid-template-columns: 1fr 480px;
      gap: var(--space-16);
    }
    .history-visual {
      height: 480px;
    }
  }

  /* Values */
  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin-top: var(--space-10);
  }

  .value-card {
    background: var(--color-surface);
    border: var(--border);
    border-top: 3px solid var(--color-gold);
    border-radius: var(--radius);
    padding: var(--space-8);
    text-align: center;
  }

  .value-card__ornament {
    display: block;
    font-size: var(--text-xl);
    color: var(--color-gold);
    margin-bottom: var(--space-4);
    opacity: 0.7;
  }

  .value-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    margin-bottom: var(--space-3);
    color: var(--color-ink);
  }

  .value-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
    margin: 0;
  }

  @media (min-width: 561px) {
    .values-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 901px) {
    .values-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Team */
  .team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-top: var(--space-10);
    max-width: 600px;
    margin-inline: auto;
  }

  .team-card {
    background: var(--color-surface);
    border: var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition);
  }

  .team-card:hover {
    box-shadow: var(--shadow);
  }

  .team-card__portrait {
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .team-card__portrait--dark {
    background: linear-gradient(160deg, #2a1a0e 0%, #4a2c17 100%);
  }
  .team-card__portrait--mid {
    background: linear-gradient(160deg, #7a4a28 0%, #a0622e 100%);
  }
  .team-card__portrait--warm {
    background: linear-gradient(160deg, #a0622e 0%, #c4855a 100%);
  }

  .team-card__initial {
    font-family: var(--font-heading);
    font-size: 5rem;
    color: rgba(255, 255, 255, 0.15);
    line-height: 1;
    user-select: none;
  }

  .team-card__body {
    padding: var(--space-6);
  }

  .team-card__name {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    margin-bottom: var(--space-1);
    color: var(--color-ink);
  }

  .team-card__role {
    display: block;
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-4);
  }

  .team-card__bio {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
    margin: 0;
  }

  @media (min-width: 901px) {
    .team-grid {
      grid-template-columns: repeat(3, 1fr);
      max-width: none;
      margin-inline: 0;
    }
  }

  /* Accreditations */
  .accreditations-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  .accreditations-card {
    border-left: 2px solid rgba(196, 149, 42, 0.4);
    padding-left: var(--space-6);
  }

  .accreditations-card__icon {
    display: block;
    color: var(--color-gold);
    font-size: var(--text-lg);
    margin-bottom: var(--space-3);
    opacity: 0.7;
  }

  .accreditations-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-md);
    color: var(--color-cream);
    margin-bottom: var(--space-3);
  }

  .accreditations-card__detail {
    font-size: var(--text-sm);
    color: var(--color-wood-light);
    line-height: var(--leading-loose);
    margin: 0;
    opacity: 0.8;
  }

  @media (min-width: 561px) {
    .accreditations-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 901px) {
    .accreditations-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
