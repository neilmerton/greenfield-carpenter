---
import { navLinks, services } from "../data/index.ts";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">Greenfield Carpentry</a>
        <p class="footer-strap-line">
          Traditional craftsmanship for the modern home.<br />
          Serving Greenfield and the wider Manchester area since 1987.
        </p>
        <p class="footer-cert">
          <span class="cert-badge">✦</span> Guild of Master Craftsmen Member
        </p>
      </div>

      <div class="footer-col">
        <p class="footer-heading">Quick Links</p>
        <ul class="footer-links">
          {
            navLinks.map((link) => {
              return (
                <li>
                  <a href={link.href}>{link.label}</a>
                </li>
              );
            })
          }
        </ul>
      </div>

      <div class="footer-col">
        <p class="footer-heading">Services</p>
        <ul class="footer-links">
          {
            services.map((service) => {
              return (
                <li>
                  <a href={`/services/#${service.id}`}>{service.title}</a>
                </li>
              );
            })
          }
        </ul>
      </div>

      <div class="footer-col">
        <p class="footer-heading">Get in Touch</p>
        <address class="footer-address">
          <p>Greenfield, Oldham<br />Greater Manchester<br />OL3 7EA</p>
          <p><a href="tel:+441457860000">01457 860 000</a></p>
          <p>
            <a href="mailto:hello@greenfieldcarpentry.co.uk"
              >hello@greenfieldcarpentry.co.uk</a
            >
          </p>
        </address>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">
        &copy; {year} Greenfield Carpentry. All rights reserved.
      </p>
      <p class="footer-note">
        Handcrafted with care in the heart of Saddleworth.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-footer-bg);
    border-top: 3px solid var(--color-gold);
    color: var(--color-parchment);
    padding-bottom: var(--space-8);
    padding-top: var(--space-20);
  }

  .footer-grid {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    display: grid;
    gap: var(--space-10);
    grid-template-columns: 1fr;
    padding-bottom: var(--space-12);
  }

  .footer-logo {
    color: var(--color-parchment);
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
  }

  .footer-logo:hover {
    color: var(--color-wood-light);
  }

  .footer-strap-line {
    color: var(--color-wood-light);
    font-size: var(--text-sm);
    line-height: var(--leading-loose);
    margin-bottom: var(--space-4);
  }

  .footer-cert {
    color: var(--color-gold-light);
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .cert-badge {
    color: var(--color-gold-light);
  }

  .footer-heading {
    color: var(--color-gold-light);
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    margin-bottom: var(--space-4);
    text-transform: uppercase;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-links a {
    color: var(--color-parchment);
    font-size: var(--text-sm);
    transition: color var(--transition);
  }

  .footer-links a:hover {
    color: var(--color-wood-light);
  }

  .footer-address {
    color: var(--color-parchment);
    display: flex;
    flex-direction: column;
    font-size: var(--text-sm);
    font-style: normal;
    gap: var(--space-3);
    line-height: var(--leading-loose);
    opacity: 0.8;
  }

  .footer-address a {
    color: inherit;
    opacity: 1;
  }

  .footer-address a:hover {
    color: var(--color-wood-light);
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    text-align: center;
    padding-top: var(--space-8);
    gap: var(--space-4);
  }

  .footer-copy {
    color: var(--color-cream);
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    opacity: 0.5;
    margin: 0;
  }

  .footer-note {
    color: var(--color-cream);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: italic;
    opacity: 0.6;
    margin: 0;
  }

  @media (min-width: 561px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
    .footer-bottom {
      flex-direction: row;
      text-align: left;
    }
  }

  @media (min-width: 901px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1.5fr;
      gap: var(--space-12);
    }
    .footer-brand {
      grid-column: auto;
    }
  }
</style>
